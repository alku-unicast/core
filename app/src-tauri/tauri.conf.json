{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UniCast",
  "version": "0.1.0",
  "identifier": "com.unicast.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UniCast",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 550,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": true
      },
      {
        "label": "streaming-bar",
        "title": "UniCast Stream",
        "width": 380,
        "height": 200,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "url": "/#/streaming-bar"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "unicast-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
